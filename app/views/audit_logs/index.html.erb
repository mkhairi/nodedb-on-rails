<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">
      Audit logs
      <span class="badge text-green-600 ml-2" data-variant="outline">BITEMPORAL</span>
    </h1>
    <div class="text-muted-foreground">
      NodeDB <code>BITEMPORAL</code> collection: every committed
      version of every row is retained. Reads <em>and</em> writes are
      plain ActiveRecord (<code>create!</code> persists and versions
      inside AR's transaction); the version trail below comes from
      <code>AuditLog.versions</code> — the
      <code>NodeDB::Bitemporal</code> concern's
      <code>AS OF SYSTEM TIME NULL</code> scan.
    </div>
  </div>
</div>

<%= form_with url: audit_logs_path, method: :post, local: true, class: "card mt-4" do |f| %>
  <section>
    <div class="grid gap-2 md:grid-cols-4">
      <div role="group" class="field">
        <%= f.label :actor %>
        <%= f.text_field :actor, class: "input", placeholder: "user@example.com" %>
      </div>
      <div role="group" class="field">
        <%= f.label :action_name, "Action" %>
        <%= f.text_field :action_name, class: "input", placeholder: "viewed" %>
      </div>
      <div role="group" class="field">
        <%= f.label :target %>
        <%= f.text_field :target, class: "input", placeholder: "/articles/42" %>
      </div>
      <div role="group" class="field">
        <%= f.label :context %>
        <%= f.text_field :context, class: "input", placeholder: "{}" %>
      </div>
    </div>
  </section>
  <footer class="justify-end">
    <%= f.submit "Record audit entry", class: "btn" %>
  </footer>
<% end %>

<div class="card mt-4">
  <header>
    <h2>Current entries</h2>
    <div class="card-action text-muted-foreground text-sm"><%= @logs.size %> rows · plain ActiveRecord</div>
  </header>
  <section>
    <div class="table-container">
      <table class="table">
        <thead>
          <tr>
            <th>Recorded at</th>
            <th>Actor</th>
            <th>Action</th>
            <th>Target</th>
            <th>Context</th>
            <th>Document id</th>
          </tr>
        </thead>
        <tbody>
          <% @logs.each do |log| %>
            <tr>
              <td class="text-muted-foreground text-sm"><%= log.recorded_at %></td>
              <td><%= log.actor %></td>
              <td><span class="badge text-blue-600" data-variant="outline"><%= log.action %></span></td>
              <td><code><%= log.target %></code></td>
              <td class="text-muted-foreground text-sm"><code><%= log.context %></code></td>
              <td class="text-muted-foreground text-sm"><code><%= log.id %></code></td>
            </tr>
          <% end %>
          <% if @logs.empty? %>
            <tr>
              <td colspan="6" class="text-muted-foreground text-center">
                No entries yet — record one above.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>

<div class="card mt-4">
  <header>
    <h2>Version history <span class="badge text-purple-600 ml-2" data-variant="outline">AS OF SYSTEM TIME NULL</span></h2>
    <div class="card-action text-muted-foreground text-sm"><%= @versions.size %> committed versions</div>
  </header>
  <section>
    <div class="table-container">
      <table class="table">
        <thead>
          <tr>
            <th>System commit (ms)</th>
            <th>Actor</th>
            <th>Action</th>
            <th>Target</th>
            <th>Document id</th>
          </tr>
        </thead>
        <tbody>
          <% @versions.each do |v| %>
            <tr>
              <td class="text-muted-foreground text-sm"><code><%= v["_ts_system"] %></code></td>
              <td><%= v["actor"] %></td>
              <td><span class="badge text-blue-600" data-variant="outline"><%= v["action"] %></span></td>
              <td><code><%= v["target"] %></code></td>
              <td class="text-muted-foreground text-sm"><code><%= v["id"] %></code></td>
            </tr>
          <% end %>
          <% if @versions.empty? %>
            <tr><td colspan="5" class="text-muted-foreground text-center">No versions yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
