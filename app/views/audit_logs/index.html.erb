<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">
        Audit logs
        <span class="badge bg-green-lt ms-2">BITEMPORAL</span>
      </h2>
      <div class="text-secondary">
        NodeDB <code>BITEMPORAL</code> collection: every committed
        version of every row is retained. Current-state reads are plain
        ActiveRecord; the version trail below comes from
        <code>SELECT * FROM audit_logs AS OF SYSTEM TIME NULL</code>.
      </div>
    </div>
  </div>
</div>

<div class="alert alert-warning d-flex align-items-start mt-3">
  <i class="ti ti-alert-triangle me-2 mt-1"></i>
  <div>
    <strong>Writes bypass ActiveRecord's save path.</strong>
    NodeDB currently loses INSERTs committed inside explicit
    transactions on bitemporal collections (tracked as BUG-024), and AR
    wraps every <code>save</code> in one. <code>AuditLog.record!</code>
    validates through the model, then issues a raw autocommit INSERT —
    which persists correctly. Collapse to plain <code>create!</code>
    when upstream fixes the transactional write path.
  </div>
</div>

<%= form_with url: audit_logs_path, method: :post, local: true, class: "card mt-3" do |f| %>
  <div class="card-body">
    <div class="row g-2">
      <div class="col-md-3">
        <%= f.label :actor, class: "form-label" %>
        <%= f.text_field :actor, class: "form-control", placeholder: "user@example.com" %>
      </div>
      <div class="col-md-3">
        <%= f.label :action_name, "Action", class: "form-label" %>
        <%= f.text_field :action_name, class: "form-control", placeholder: "viewed" %>
      </div>
      <div class="col-md-3">
        <%= f.label :target, class: "form-label" %>
        <%= f.text_field :target, class: "form-control", placeholder: "/articles/42" %>
      </div>
      <div class="col-md-3">
        <%= f.label :context, class: "form-label" %>
        <%= f.text_field :context, class: "form-control", placeholder: "{}" %>
      </div>
    </div>
  </div>
  <div class="card-footer text-end">
    <%= f.submit "Record audit entry", class: "btn btn-primary" %>
  </div>
<% end %>

<div class="card mt-3">
  <div class="card-header">
    <h3 class="card-title">Current entries</h3>
    <div class="text-secondary small ms-auto"><%= @logs.size %> rows · plain ActiveRecord</div>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead>
        <tr>
          <th>Recorded at</th>
          <th>Actor</th>
          <th>Action</th>
          <th>Target</th>
          <th>Context</th>
          <th>Document id</th>
        </tr>
      </thead>
      <tbody>
        <% @logs.each do |log| %>
          <tr>
            <td class="text-secondary small"><%= log.recorded_at %></td>
            <td><%= log.actor %></td>
            <td><span class="badge bg-blue-lt"><%= log.action %></span></td>
            <td><code><%= log.target %></code></td>
            <td class="text-secondary small"><code><%= log.context %></code></td>
            <td class="text-secondary small"><code><%= log.id %></code></td>
          </tr>
        <% end %>
        <% if @logs.empty? %>
          <tr>
            <td colspan="6" class="text-secondary text-center">
              No entries yet — record one above.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="card mt-3">
  <div class="card-header">
    <h3 class="card-title">Version history <span class="badge bg-purple-lt ms-2">AS OF SYSTEM TIME NULL</span></h3>
    <div class="text-secondary small ms-auto"><%= @versions.size %> committed versions</div>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead>
        <tr>
          <th>System commit (ms)</th>
          <th>Actor</th>
          <th>Action</th>
          <th>Target</th>
          <th>Document id</th>
        </tr>
      </thead>
      <tbody>
        <% @versions.each do |v| %>
          <tr>
            <td class="text-secondary small"><code><%= v["_ts_system"] %></code></td>
            <td><%= v["actor"] %></td>
            <td><span class="badge bg-blue-lt"><%= v["action"] %></span></td>
            <td><code><%= v["target"] %></code></td>
            <td class="text-secondary small"><code><%= v["id"] %></code></td>
          </tr>
        <% end %>
        <% if @versions.empty? %>
          <tr><td colspan="5" class="text-secondary text-center">No versions yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
