<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>NodeDB On Rails</title>
    <%= csrf_meta_tags %>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/basecoat-css@1.0.2/dist/basecoat.cdn.min.css"
          integrity="sha384-XWKdrxzE2X33lI8Q03C9fIbqdLWV11whVNycR2/3bMNJY73EEQOa7rmN+SeiSCor"
          crossorigin="anonymous" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.34.1/dist/tabler-icons.min.css"
          integrity="sha384-0qlw5FfXiK9KETSJ39fi9FNuVP+qL9XLrBRZzKDD9J0YGvIoZ/r9I/EmZDcoYwEq"
          crossorigin="anonymous" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.1.11/dist/index.global.js"
            integrity="sha384-XXN6/S6yXj8EpXnBTw3JGR9ZM+hixGxFCLYn0FHtg9cWh0ziKmAgTPEhecbCDOmj"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/basecoat-css@1.0.2/dist/js/all.min.js"
            integrity="sha384-rD2ZCuReXV7nIneJcn1lsTn6yOv87YARLQyUsemVAxrYYHdy5hcAW8XZEQxx87Dj"
            crossorigin="anonymous" defer></script>
    <script type="module"
            src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.23/dist/turbo.es2017-esm.min.js"
            integrity="sha384-30xj23yZCxfjTlTA5+MpucLhQbkG4R+JxcbUo8fIZUp/4rdEHdpkOW1opBs2xd/p"
            crossorigin="anonymous"></script>
    <style>
      /* Basecoat keys alert icon layout on a direct <svg> child; mirror
         those rules for the Tabler icon font we use instead. */
      .alert:has(> i.ti) {
        column-gap: calc(var(--spacing) * 2.5);
        grid-template-columns: auto 1fr;
      }
      .alert > i.ti {
        grid-row: span 2 / span 2;
        translate: 0 calc(var(--spacing) * 0.5);
        font-size: 1rem;
        line-height: 1;
      }
      .alert:has(> i.ti) > :is(h2, h3, h4, h5, h6, strong) {
        grid-column-start: 2;
      }

      /* Basecoat ships no pre/code styling and Tailwind preflight strips
         the browser defaults; unlayered rules here win over its base layer. */
      pre {
        background: var(--muted);
        border: 1px solid var(--border);
        border-radius: calc(var(--radius) - 2px);
        padding: calc(var(--spacing) * 3);
        overflow-x: auto;
        font-size: 0.8125rem;
        line-height: 1.6;
      }
      code {
        font-family: var(--font-mono);
        font-size: 0.8125em;
      }
      :not(pre) > code {
        background: var(--muted);
        border: 1px solid var(--border);
        border-radius: calc(var(--radius) - 4px);
        padding: calc(var(--spacing) * 0.5) calc(var(--spacing) * 1.5);
        white-space: nowrap;
      }
      pre code {
        font-size: inherit;
      }
    </style>
  </head>
  <body>
    <aside id="sidebar" class="sidebar" data-side="left">
      <nav aria-label="Sidebar navigation">
        <header>
          <%= link_to root_path, class: "flex items-center gap-2 px-2 py-1 font-semibold" do %>
            <i class="ti ti-database text-primary"></i>
            <span>NodeDB On Rails</span>
            <span class="badge" data-variant="outline">alpha</span>
          <% end %>
        </header>
        <section class="scrollbar-sm">
          <div role="group" aria-labelledby="group-label-engines">
            <h3 id="group-label-engines">Engines</h3>
            <ul>
              <% [
                ["articles",  articles_path,      "ti-files",            "Articles"],
                ["posts",     posts_path,         "ti-search",           "Posts (FTS)"],
                ["locations", locations_path,     "ti-map-pin",          "Locations & Map"],
                ["social",    social_nodes_path,  "ti-affiliate",        "Social Graph"],
                ["metrics",   metrics_path,       "ti-chart-line",       "Timeseries"],
                ["vectors",   embeddings_path,    "ti-vector-triangle",  "Vector search"],
                ["kv",        kv_sessions_path,   "ti-key",              "KV Store"],
                ["files",     stored_files_path,  "ti-file-upload",      "File store"],
                ["audit",     audit_logs_path,    "ti-clock-hour-3",     "Audit (bitemporal)"],
                ["tenants",   tenants_path,       "ti-building-community", "Tenants"],
                ["info",      server_info_path,   "ti-server",           "Server info"]
              ].each do |slug, path, icon, label| %>
                <% active = current_page?(path) || (slug == "social" && controller_name == "social_nodes") %>
                <li>
                  <%= link_to path, "aria-current": (active ? "page" : nil) do %>
                    <i class="ti <%= icon %>"></i>
                    <span><%= label %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
          <div role="group" aria-labelledby="group-label-help">
            <h3 id="group-label-help">Help</h3>
            <ul>
              <li>
                <%= link_to docs_path, "aria-current": (current_page?(docs_path) ? "page" : nil) do %>
                  <i class="ti ti-book"></i>
                  <span>Docs</span>
                <% end %>
              </li>
            </ul>
          </div>
        </section>
      </nav>
    </aside>

    <main class="min-h-dvh flex flex-col">
      <header class="flex items-center gap-2 border-b px-4 py-2 md:hidden">
        <button type="button" class="btn" data-variant="ghost" data-size="icon"
                aria-label="Toggle sidebar"
                onclick="document.getElementById('sidebar')?.toggle()">
          <i class="ti ti-menu-2"></i>
        </button>
        <span class="font-semibold">NodeDB On Rails</span>
      </header>

      <div class="mx-auto w-full max-w-6xl flex-1 px-4 py-6 lg:px-8">
        <% flash.each do |key, msg| %>
          <% destructive = key.to_s == "alert" %>
          <div class="alert mb-4" <%= 'data-variant="destructive"'.html_safe if destructive %> role="alert">
            <i class="ti <%= destructive ? 'ti-alert-circle' : 'ti-check' %>"></i>
            <h2><%= msg %></h2>
          </div>
        <% end %>
        <%= yield %>
      </div>

      <footer class="border-t px-4 py-4 lg:px-8">
        <div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-between gap-2 text-sm text-muted-foreground lg:flex-row">
          <ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
            <li>
              <a href="https://github.com/mkhairi/activerecord-nodedb-adapter"
                 class="hover:underline">activerecord-nodedb-adapter</a>
            </li>
            <li>
              <a href="https://github.com/mkhairi/nodedb-ruby"
                 class="hover:underline">nodedb-ruby</a>
            </li>
            <li>
              <a href="https://github.com/mkhairi/nodedb-on-rails"
                 class="hover:underline">nodedb-on-rails</a>
            </li>
            <li>
              <a href="https://github.com/mkhairi/activerecord-nodedb-adapter/issues?q=%22%5Bupstream%3ANodeDB%5D%22"
                 class="hover:underline">bug tracker</a>
            </li>
            <li>
              <a href="https://github.com/mkhairi/activerecord-nodedb-adapter/blob/main/docs/KNOWN_ISSUES.md"
                 class="hover:underline">known issues</a>
            </li>
          </ul>
          <ul class="flex items-center gap-4">
            <li>Rails <%= Rails.version %></li>
            <li>Ruby <%= RUBY_VERSION %></li>
          </ul>
        </div>
      </footer>
    </main>
  </body>
</html>
