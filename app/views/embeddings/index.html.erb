<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Vector search</h1>
    <div class="text-muted-foreground">NodeDB vector engine · <code>embeddings</code> · dim 3 · cosine</div>
  </div>
</div>

<% if @error %>
  <div class="alert mt-4" role="alert">
    <i class="ti ti-alert-circle"></i>
    <h2><%= @error %></h2>
  </div>
<% end %>

<div class="alert mt-4 mb-0" role="alert">
  <i class="ti ti-info-circle"></i>
  <h2>Fixed seed catalog</h2>
  <section>
    NodeDB <code>SEARCH … USING VECTOR()</code> projects
    <code>id</code> / <code>_surrogate</code> / <code>distance</code>
    result columns (no document fields), so the catalog below is the
    fixed seed set. Works identically over pgwire and native.
  </section>
</div>

<div class="grid gap-4 mt-4 lg:grid-cols-2">
  <div>
    <div class="card h-full">
      <header><h2>Nearest-neighbour search</h2></header>
      <section>
        <%= form_with url: search_embeddings_path, method: :get, local: true, class: "flex gap-2" do |f| %>
          <div class="flex-1">
            <%= f.text_field :q, value: params[:q], class: "input", placeholder: "query vector e.g. 0.1, 0.2, 0.3" %>
          </div>
          <div><%= f.submit "Search", class: "btn" %></div>
        <% end %>

        <% if @results.any? %>
          <div class="table-container mt-4">
            <table class="table">
              <thead><tr><th>#</th><th>Surrogate</th><th>Title</th><th class="text-end">Distance</th></tr></thead>
              <tbody>
                <% @results.each_with_index do |r, i| %>
                  <tr>
                    <td class="text-muted-foreground"><%= i + 1 %></td>
                    <td><code><%= r["surrogate"] %></code></td>
                    <td><%= r["title"] || "(ad-hoc)" %></td>
                    <td class="text-end"><code><%= r["distance"].round(4) rescue r["distance"] %></code></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% elsif params[:q].present? %>
          <p class="text-muted-foreground mb-0 mt-4">No neighbours returned.</p>
        <% end %>
      </section>
    </div>

    <div class="card mt-4">
      <header><h2>Add embedding</h2></header>
      <section>
        <%= form_with url: embeddings_path, method: :post, local: true, class: "grid grid-cols-12 gap-2" do |f| %>
          <div class="col-span-5">
            <%= f.text_field :title, class: "input", placeholder: "title" %>
          </div>
          <div class="col-span-4">
            <%= f.text_field :embedding, class: "input", placeholder: "0.1, 0.2, 0.3" %>
          </div>
          <div class="col-span-3">
            <%= f.submit "Add", class: "btn w-full" %>
          </div>
        <% end %>
        <p class="text-muted-foreground text-sm mt-2 mb-0">Added vectors are searchable but not listed in the seed catalog.</p>
      </section>
    </div>
  </div>

  <div>
    <div class="card h-full">
      <header><h2>Seed catalog</h2></header>
      <section>
        <div class="table-container">
          <table class="table">
            <thead><tr><th>#</th><th>Title</th><th>Vector</th></tr></thead>
            <tbody>
              <% @catalog.each_with_index do |s, i| %>
                <tr>
                  <td class="text-muted-foreground"><%= i %></td>
                  <td><%= s[:title] %></td>
                  <td><code>[<%= s[:vec].join(", ") %>]</code></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
      <footer class="text-muted-foreground text-sm">
        Surrogate <code>#</code> in results maps to this row index.
      </footer>
    </div>
  </div>
</div>
