<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title"><%= @post.title %></h2>
      <div class="text-secondary small"><code><%= @post.id %></code></div>
    </div>
    <div class="col-auto btn-list">
      <%= link_to posts_path, class: "btn" do %><i class="ti ti-arrow-left me-1"></i> All<% end %>
      <%= link_to edit_post_path(@post), class: "btn btn-primary" do %><i class="ti ti-edit me-1"></i> Edit<% end %>
      <%= button_to post_path(@post), method: :delete, data: { turbo_confirm: "Sure?" }, class: "btn btn-ghost-danger" do %>
        <i class="ti ti-trash me-1"></i> Delete
      <% end %>
    </div>
  </div>
</div>

<div class="card mt-3">
  <div class="card-body" style="white-space: pre-wrap;"><%= @post.body %></div>
</div>
