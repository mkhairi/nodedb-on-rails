<div class="mb-6 flex flex-wrap items-center justify-between gap-4 print:hidden">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight"><%= @post.title %></h1>
    <div class="text-sm text-muted-foreground"><code><%= @post.id %></code></div>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to posts_path, class: "btn", data: { variant: "outline" } do %><i class="ti ti-arrow-left mr-1"></i> All<% end %>
    <%= link_to edit_post_path(@post), class: "btn" do %><i class="ti ti-edit mr-1"></i> Edit<% end %>
    <%= button_to post_path(@post), method: :delete, data: { turbo_confirm: "Sure?", variant: "ghost" }, class: "btn text-destructive" do %>
      <i class="ti ti-trash mr-1"></i> Delete
    <% end %>
  </div>
</div>

<div class="card mt-4">
  <section style="white-space: pre-wrap;"><%= @post.body %></section>
</div>
