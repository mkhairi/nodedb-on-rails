<div class="mb-6 flex flex-wrap items-center justify-between gap-4 print:hidden">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Posts</h1>
    <div class="text-muted-foreground"><%= pluralize(@posts.size, "post") %> · powered by NodeDB FTS</div>
  </div>
  <div class="flex gap-2">
    <%= link_to new_post_path, class: "btn" do %>
      <i class="ti ti-plus mr-1"></i> New post
    <% end %>
  </div>
</div>

<div class="card mt-4">
  <section class="border-b py-3">
    <%= form_with url: search_posts_path, method: :get, local: true, class: "flex gap-2" do |f| %>
      <div class="relative flex-1">
        <span class="absolute inset-y-0 left-3 flex items-center text-muted-foreground"><i class="ti ti-search"></i></span>
        <%= f.text_field :q, value: @query, placeholder: "Full-text search…", class: "input pl-9" %>
      </div>
      <div><%= f.submit "Search", class: "btn" %></div>
    <% end %>
  </section>

  <% if @query.present? %>
    <section class="border-b">
      <h2 class="font-semibold">FTS results — <%= @hits.size %> hit(s) for <em>“<%= @query %>”</em></h2>
      <% if @hits.empty? %>
        <p class="text-muted-foreground">No matches.</p>
      <% else %>
        <div class="table-container">
          <table class="table">
            <thead><tr><th>Title</th><th>Body</th></tr></thead>
            <tbody>
            <% @hits.each do |h| %>
              <tr>
                <td><%= link_to h[:post]&.title || "(missing)", post_path(h[:id]) %></td>
                <td class="text-muted-foreground"><%= truncate(h[:post]&.body.to_s, length: 80) %></td>
              </tr>
            <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </section>
  <% end %>

  <% if @posts.any? %>
    <div class="divide-y">
      <% @posts.each do |p| %>
        <%= link_to post_path(p), class: "block px-6 py-3 hover:bg-muted" do %>
          <div class="flex items-center gap-4">
            <div class="flex-1">
              <strong><%= p.title %></strong>
              <div class="text-sm text-muted-foreground"><%= truncate(p.body.to_s, length: 90) %></div>
            </div>
            <div class="text-sm text-muted-foreground"><i class="ti ti-chevron-right"></i></div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <section>
      <div class="flex flex-col items-center gap-2 py-12 text-muted-foreground">
        <i class="ti ti-message-off text-4xl"></i>
        <div>No posts yet. <%= link_to "Write one", new_post_path %>.</div>
      </div>
    </section>
  <% end %>
</div>
