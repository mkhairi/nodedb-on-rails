<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">File store</h1>
    <div class="text-muted-foreground">
      <%= pluralize(@files.size, "file") %> — payloads on the <code>kv</code> engine
      (Base64), metadata on <code>document_strict</code>
    </div>
  </div>
</div>

<div class="grid gap-4 mt-4 md:grid-cols-12">
  <div class="md:col-span-5">
    <div class="card">
      <header><h2>Upload</h2></header>
      <section>
        <%= form_with url: stored_files_path, method: :post, local: true, multipart: true do |f| %>
          <div role="group" class="field mb-4">
            <%= f.file_field :file, class: "input" %>
            <p>
              Max <%= number_to_human_size(StoredFile::MAX_BYTES) %> —
              stored as a single kv value; NodeDB's WAL caps writes at ~2&nbsp;MB.
            </p>
          </div>
          <%= f.submit "Upload", class: "btn" %>
        <% end %>
      </section>
    </div>
  </div>

  <div class="md:col-span-7">
    <div class="card">
      <header><h2>Stored files</h2></header>
      <section>
        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>Filename</th><th>Type</th><th>Size</th><th>Uploaded</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if @files.empty? %>
                <tr><td colspan="5" class="text-muted-foreground">No files yet.</td></tr>
              <% end %>
              <% @files.each do |file| %>
                <tr>
                  <td><%= link_to file.filename, stored_file_path(file), title: "Download" %></td>
                  <td><code><%= file.content_type %></code></td>
                  <td><%= number_to_human_size(file.byte_size.to_i) %></td>
                  <td class="text-muted-foreground"><%= file.uploaded_at %></td>
                  <td class="text-end">
                    <%= button_to "Delete", stored_file_path(file), method: :delete,
                          class: "btn text-destructive", "data-variant": "ghost", "data-size": "sm",
                          form: { data: { turbo_confirm: "Delete #{file.filename}?" } } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </div>
</div>
