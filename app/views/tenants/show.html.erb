<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">
      Tenant: <code><%= @tenant.id %></code>
      <span class="badge text-sky-600 ml-2" data-variant="outline">ISOLATED SESSION</span>
    </h1>
    <div class="text-muted-foreground">
      Everything below ran over a fresh <code>NodeDB::Connection</code>
      authenticated as <code><%= @tenant.username %></code> — inside this
      tenant's isolation boundary, not the app's superuser connection.
    </div>
  </div>
  <div class="flex gap-2">
    <%= link_to tenants_path, class: "btn", data: { variant: "outline" } do %>
      <i class="ti ti-arrow-left mr-1"></i> All tenants
    <% end %>
  </div>
</div>

<div class="mt-4 grid gap-4 lg:grid-cols-2">
  <div class="space-y-4">
    <div class="card">
      <header>
        <h2>Isolation proof</h2>
      </header>
      <section>
        <p class="text-muted-foreground text-sm mb-2">
          The default tenant's <code>articles</code> collection exists and is
          readable on the app's normal connection — but from this tenant's
          session the same query fails:
        </p>
        <div class="mb-2"><code>SELECT id FROM articles LIMIT 1</code></div>
        <% if @isolation_error %>
          <div class="alert" role="alert">
            <i class="ti ti-shield-check"></i>
            <h2><code><%= @isolation_error %></code></h2>
          </div>
        <% else %>
          <div class="alert" role="alert" data-variant="destructive">
            <i class="ti ti-shield-x"></i>
            <h2>Query unexpectedly succeeded — isolation boundary not enforced!</h2>
          </div>
        <% end %>
      </section>
    </div>

    <div class="card">
      <header>
        <h2>This tenant's collections</h2>
        <div class="card-action text-muted-foreground text-sm"><code>SHOW COLLECTIONS</code> as <code><%= @tenant.username %></code></div>
      </header>
      <section>
        <div class="table-container">
          <table class="table">
            <thead><tr><th>Name</th><th>Owner</th></tr></thead>
            <tbody>
              <% @collections.each do |c| %>
                <tr>
                  <td><code><%= c["name"] %></code></td>
                  <td class="text-muted-foreground text-sm"><%= c["owner"] %></td>
                </tr>
              <% end %>
              <% if @collections.empty? %>
                <tr><td colspan="2" class="text-muted-foreground text-center">No collections yet.</td></tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <% if @counters %>
      <div class="card">
        <header>
          <h2>Counters</h2>
          <div class="card-action text-muted-foreground text-sm"><code>SHOW TENANT <%= @tenant.id %></code></div>
        </header>
        <section>
          <dl class="grid gap-x-8 gap-y-2 sm:grid-cols-2">
            <% @counters.each do |k, v| %>
              <dt class="text-sm text-muted-foreground"><%= k %></dt>
              <dd class="font-medium"><code><%= v %></code></dd>
            <% end %>
          </dl>
        </section>
      </div>
    <% end %>
  </div>

  <div>
    <div class="card h-full">
      <header>
        <h2>Notes <span class="badge text-blue-600 ml-2" data-variant="outline">tenant_notes</span></h2>
        <div class="card-action text-muted-foreground text-sm"><%= @notes.size %> rows · written inside the tenant</div>
      </header>
      <section class="border-b pb-4">
        <%= form_with url: add_note_tenant_path(@tenant), method: :post, local: true do |f| %>
          <div class="flex gap-2">
            <%= f.text_field :body, class: "input", placeholder: "note body…" %>
            <%= f.submit "Add note", class: "btn" %>
          </div>
          <p class="text-muted-foreground text-sm mt-1">
            The <code>tenant_notes</code> collection is created on first use —
            by the tenant user, homed to this tenant.
          </p>
        <% end %>
      </section>
      <section>
        <div class="table-container">
          <table class="table">
            <thead><tr><th>Created</th><th>Body</th><th>Id</th></tr></thead>
            <tbody>
              <% @notes.each do |n| %>
                <tr>
                  <td class="text-muted-foreground text-sm"><%= n["created_at"] %></td>
                  <td><%= n["body"] %></td>
                  <td class="text-muted-foreground text-sm"><code><%= n["id"] %></code></td>
                </tr>
              <% end %>
              <% if @notes.empty? %>
                <tr><td colspan="3" class="text-muted-foreground text-center">No notes yet — add one above.</td></tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </div>
</div>
