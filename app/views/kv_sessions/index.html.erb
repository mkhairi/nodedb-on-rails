<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">KV store</h2>
      <div class="text-secondary"><%= pluralize(@entries.size, "entry") %></div>
    </div>
  </div>
</div>

<div class="row mt-3 g-3">
  <div class="col-md-7">
    <div class="card h-100">
      <div class="card-header"><h3 class="card-title">Set / overwrite</h3></div>
      <div class="card-body">
        <%= form_with url: kv_sessions_path, method: :post, local: true, class: "row g-2" do |f| %>
          <div class="col-md-4">
            <%= f.label :key, class: "form-label" %>
            <%= f.text_field :key, placeholder: "session_abc", class: "form-control" %>
          </div>
          <div class="col-md-6">
            <%= f.label :value, class: "form-label" %>
            <%= f.text_field :value, placeholder: "token-xyz", class: "form-control" %>
          </div>
          <div class="col-md-2 d-flex align-items-end">
            <%= f.submit "Save", class: "btn btn-primary w-100" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-5">
    <div class="card h-100">
      <div class="card-header"><h3 class="card-title">Lookup</h3></div>
      <div class="card-body">
        <%= form_with url: kv_sessions_path, method: :get, local: true, class: "row g-2" do |f| %>
          <div class="col">
            <%= f.text_field :k, value: @lookup_key, placeholder: "key…", class: "form-control" %>
          </div>
          <div class="col-auto">
            <%= f.submit "Get", class: "btn" %>
          </div>
        <% end %>
        <% if @lookup_key.present? %>
          <div class="mt-3">
            <div class="text-secondary small">Result for <code><%= @lookup_key %></code></div>
            <% if @lookup_value.nil? %>
              <span class="badge bg-orange-lt">not set</span>
            <% else %>
              <code class="d-block mt-1 p-2 bg-light rounded"><%= @lookup_value %></code>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="card mt-3">
  <div class="card-header"><h3 class="card-title">All entries</h3></div>
  <% if @entries.any? %>
    <div class="table-responsive">
      <table class="table table-vcenter card-table">
        <thead><tr><th>Key</th><th>Value</th><th class="w-1"></th></tr></thead>
        <tbody>
        <% @entries.each do |e| %>
          <tr>
            <td><code><%= e.key %></code></td>
            <td><code><%= e.value %></code></td>
            <td>
              <%= button_to kv_session_path(key: e.key), method: :delete, data: { turbo_confirm: "Sure?" }, class: "btn btn-sm btn-ghost-danger" do %>
                <i class="ti ti-trash"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-body text-center text-secondary py-5">
      <i class="ti ti-key-off display-4 d-block mb-2"></i>
      No entries yet.
    </div>
  <% end %>
</div>
