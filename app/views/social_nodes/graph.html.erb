<div class="mb-6 flex flex-wrap items-center justify-between gap-4 print:hidden">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Graph + PageRank</h1>
  </div>
  <div>
    <%= link_to social_nodes_path, class: "btn", data: { variant: "outline" } do %><i class="ti ti-arrow-left mr-1"></i> Back<% end %>
  </div>
</div>

<% if @error %>
  <div class="alert mt-4" role="alert" data-variant="destructive">
    <i class="ti ti-alert-circle"></i>
    <h2><%= @error %></h2>
  </div>
<% end %>

<% if @stats %>
  <div class="card mt-4">
    <header>
      <h2>Graph stats <span class="badge ml-2" data-variant="outline">NodeDB v0.3.0</span></h2>
      <div class="card-action text-sm text-muted-foreground">SHOW GRAPH STATS — persistent O(1) edge-store counters</div>
    </header>
    <section>
      <div class="grid gap-4 md:grid-cols-4">
        <div>
          <div class="text-muted-foreground">Nodes</div>
          <div class="text-3xl font-semibold"><%= @stats["node_count"] %></div>
        </div>
        <div>
          <div class="text-muted-foreground">Edges</div>
          <div class="text-3xl font-semibold"><%= @stats["edge_count"] %></div>
        </div>
        <div>
          <div class="text-muted-foreground">Distinct labels</div>
          <div class="text-3xl font-semibold"><%= @stats["distinct_label_count"] %></div>
        </div>
        <div>
          <div class="text-muted-foreground">Label breakdown</div>
          <% if @stats_labels.any? %>
            <div class="mt-1 flex flex-wrap gap-1">
              <% @stats_labels.each do |entry| %>
                <span class="badge" data-variant="secondary"><%= entry["label"] %> · <%= entry["count"] %></span>
              <% end %>
            </div>
          <% else %>
            <span class="text-muted-foreground">—</span>
          <% end %>
        </div>
      </div>
    </section>
  </div>
<% end %>

<% sorted = @nodes.sort_by { |n| -(@pagerank[n.id] || 0.0) } %>
<% max = sorted.map { |n| @pagerank[n.id] || 0.0 }.max || 1.0 %>
<% max = 1.0 if max.zero? %>

<div class="card mt-4">
  <div class="table-container">
    <table class="table">
      <thead><tr><th>Node</th><th>Name</th><th>Score</th><th>Bar</th></tr></thead>
      <tbody>
      <% sorted.each do |n| %>
        <% score = @pagerank[n.id] || 0.0 %>
        <tr>
          <td><code><%= n.id %></code></td>
          <td><%= n.name %></td>
          <td><span class="badge" data-variant="secondary"><%= score.round(5) %></span></td>
          <td style="width: 30%;">
            <div class="h-2 w-full overflow-hidden rounded-full bg-muted">
              <div class="h-full rounded-full bg-primary" style="width: <%= ((score / max) * 100).round %>%"></div>
            </div>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
