<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">Graph + PageRank</h2>
    </div>
    <div class="col-auto">
      <%= link_to social_nodes_path, class: "btn" do %><i class="ti ti-arrow-left me-1"></i> Back<% end %>
    </div>
  </div>
</div>

<% if @error %>
  <div class="alert alert-danger mt-3"><i class="ti ti-alert-circle me-1"></i> <%= @error %></div>
<% end %>

<% if @stats %>
  <div class="card mt-3">
    <div class="card-header">
      <h3 class="card-title">Graph stats <span class="badge bg-azure-lt ms-2">NodeDB v0.3.0</span></h3>
      <div class="text-secondary small ms-auto">SHOW GRAPH STATS — persistent O(1) edge-store counters</div>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-3">
          <div class="text-secondary">Nodes</div>
          <div class="h2 mb-0"><%= @stats["node_count"] %></div>
        </div>
        <div class="col-md-3">
          <div class="text-secondary">Edges</div>
          <div class="h2 mb-0"><%= @stats["edge_count"] %></div>
        </div>
        <div class="col-md-3">
          <div class="text-secondary">Distinct labels</div>
          <div class="h2 mb-0"><%= @stats["distinct_label_count"] %></div>
        </div>
        <div class="col-md-3">
          <div class="text-secondary">Label breakdown</div>
          <% if @stats_labels.any? %>
            <% @stats_labels.each do |entry| %>
              <span class="badge bg-blue-lt me-1"><%= entry["label"] %> · <%= entry["count"] %></span>
            <% end %>
          <% else %>
            <span class="text-secondary">—</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% sorted = @nodes.sort_by { |n| -(@pagerank[n.id] || 0.0) } %>
<% max = sorted.map { |n| @pagerank[n.id] || 0.0 }.max || 1.0 %>
<% max = 1.0 if max.zero? %>

<div class="card mt-3">
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead><tr><th>Node</th><th>Name</th><th>Score</th><th>Bar</th></tr></thead>
      <tbody>
      <% sorted.each do |n| %>
        <% score = @pagerank[n.id] || 0.0 %>
        <tr>
          <td><code><%= n.id %></code></td>
          <td><%= n.name %></td>
          <td><span class="badge bg-blue-lt"><%= score.round(5) %></span></td>
          <td style="width: 30%;">
            <div class="progress progress-sm">
              <div class="progress-bar bg-azure" style="width: <%= ((score / max) * 100).round %>%"></div>
            </div>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
