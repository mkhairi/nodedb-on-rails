<div class="mb-6 flex flex-wrap items-center justify-between gap-4 print:hidden">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Social graph</h1>
    <p class="text-muted-foreground"><%= pluralize(@nodes.size, "node") %></p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to graph_social_nodes_path, class: "btn", data: { variant: "outline" } do %><i class="ti ti-chart-radar mr-1"></i> PageRank<% end %>
    <%= link_to recommend_social_nodes_path, class: "btn", data: { variant: "outline" } do %><i class="ti ti-target mr-1"></i> Personalized PR<% end %>
    <%= link_to new_social_node_path, class: "btn" do %><i class="ti ti-plus mr-1"></i> Add node<% end %>
  </div>
</div>

<div class="mt-4 grid gap-4 md:grid-cols-2">
  <div class="card h-full">
    <header>
      <h2>Add edge</h2>
    </header>
    <section>
      <%= form_with url: edge_social_nodes_path, method: :post, local: true, html: { class: "space-y-6" } do |f| %>
        <div role="group" class="field">
          <%= f.label :from %>
          <%= f.select :from, @nodes.map { |n| ["#{n.name} (#{n.id})", n.id] }, {}, { class: "select" } %>
        </div>
        <div role="group" class="field">
          <%= f.label :to %>
          <%= f.select :to, @nodes.map { |n| ["#{n.name} (#{n.id})", n.id] }, {}, { class: "select" } %>
        </div>
        <div role="group" class="field">
          <%= f.label :edge_type, "Edge type" %>
          <%= f.text_field :edge_type, value: "follows", class: "input" %>
        </div>
        <%= f.submit "Connect", class: "btn" %>
      <% end %>
    </section>
  </div>

  <div class="card h-full">
    <header>
      <h2>Traverse</h2>
    </header>
    <section>
      <%= form_with url: social_nodes_path, method: :get, local: true, html: { class: "space-y-6" } do |f| %>
        <div role="group" class="field">
          <%= f.label :from %>
          <%= f.select :from, @nodes.map { |n| ["#{n.name} (#{n.id})", n.id] }, { selected: @from }, { class: "select" } %>
        </div>
        <div role="group" class="field">
          <%= f.label :depth %>
          <%= f.number_field :depth, value: @depth, min: 1, max: 6, class: "input" %>
        </div>
        <%= f.submit "Traverse", class: "btn", data: { variant: "outline" } %>
      <% end %>

      <% if @reachable %>
        <hr class="my-4">
        <p class="mb-2 text-sm text-muted-foreground">From <code><%= @from %></code> at depth <%= @depth %> — <%= @reachable.size %> reachable</p>
        <div class="flex flex-wrap gap-1">
          <% @reachable.each do |id| %><span class="badge" data-variant="secondary"><%= id %></span><% end %>
        </div>
      <% end %>
    </section>
  </div>
</div>

<div class="card mt-4">
  <header>
    <h2>Nodes</h2>
  </header>
  <div class="table-container border-t">
    <table class="table">
      <thead><tr><th>ID</th><th>Name</th><th class="w-px"></th></tr></thead>
      <tbody>
      <% @nodes.each do |n| %>
        <tr>
          <td><code><%= n.id %></code></td>
          <td><%= n.name %></td>
          <td>
            <%= button_to social_node_path(n.id), method: :delete, data: { turbo_confirm: "Sure?", variant: "ghost", size: "icon-sm" }, class: "btn text-destructive" do %>
              <i class="ti ti-trash"></i>
            <% end %>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
