<div class="mb-6 flex flex-wrap items-center justify-between gap-4 print:hidden">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">
      Personalized PageRank
      <span class="badge ml-2" data-variant="outline">NodeDB v0.3.0</span>
    </h1>
    <p class="text-muted-foreground">
      Bias the PageRank teleport vector toward a seed node. Demonstrates
      the <code>PERSONALIZATION {…}</code> clause on
      <code>GRAPH ALGO PAGERANK</code> and the Hash-to-JSON encoding
      landed in <code>nodedb-ruby 0.1.0.alpha.5</code>.
    </p>
  </div>
  <div>
    <%= link_to social_nodes_path, class: "btn", data: { variant: "outline" } do %>
      <i class="ti ti-arrow-left mr-1"></i> Back
    <% end %>
  </div>
</div>

<%= form_with url: recommend_social_nodes_path, method: :get, local: true, class: "mt-4" do |f| %>
  <div class="flex flex-wrap items-end gap-2">
    <div role="group" class="field w-full md:w-1/3">
      <label>Seed node</label>
      <%= f.select :seed, @nodes.map { |n| [n.id, n.id] }, { include_blank: "— pick a node —", selected: @seed },
                   class: "select" %>
    </div>
    <div>
      <%= f.submit "Recommend", class: "btn" %>
    </div>
  </div>
<% end %>

<% if @error %>
  <div class="alert mt-4" role="alert" data-variant="destructive">
    <i class="ti ti-alert-circle"></i>
    <h2><%= @error %></h2>
  </div>
<% end %>

<% if @seed %>
  <% ranked = @nodes.reject { |n| n.id == @seed }.sort_by { |n| -(@ranks[n.id] || 0.0) } %>
  <% max = (ranked.map { |n| @ranks[n.id] || 0.0 }.max || 0.0).nonzero? || 1.0 %>

  <div class="card mt-4">
    <header>
      <h2>Top recommendations for <code><%= @seed %></code></h2>
      <div class="card-action text-sm text-muted-foreground">
        <code>personalization: { "<%= @seed %>" =&gt; 1.0 }</code>
      </div>
    </header>
    <div class="table-container border-t">
      <table class="table">
        <thead>
          <tr><th>Node</th><th>Name</th><th>Score</th><th>Bias</th></tr>
        </thead>
        <tbody>
          <% if ranked.empty? %>
            <tr><td colspan="4" class="text-center text-muted-foreground">No other nodes to rank.</td></tr>
          <% else %>
            <% ranked.each do |n| %>
              <% score = @ranks[n.id] || 0.0 %>
              <tr>
                <td><code><%= n.id %></code></td>
                <td><%= n.name %></td>
                <td><span class="badge" data-variant="secondary"><%= score.round(5) %></span></td>
                <td style="width: 35%;">
                  <div class="h-2 w-full overflow-hidden rounded-full bg-muted">
                    <div class="h-full rounded-full bg-primary" style="width: <%= ((score / max) * 100).round %>%"></div>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="mt-4 flex flex-col items-center gap-2 py-12 text-center text-muted-foreground">
    <p class="font-medium text-foreground">Pick a seed node to personalize the ranking.</p>
    <p>
      The standard PageRank view (<%= link_to "Graph + PageRank", graph_social_nodes_path %>)
      uses the uniform teleport distribution. This view biases the teleport
      probability mass onto the seed so its neighborhood floats to the top.
    </p>
  </div>
<% end %>
