<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">
        Personalized PageRank
        <span class="badge bg-azure-lt ms-2">NodeDB v0.3.0</span>
      </h2>
      <div class="text-secondary">
        Bias the PageRank teleport vector toward a seed node. Demonstrates
        the <code>PERSONALIZATION {…}</code> clause on
        <code>GRAPH ALGO PAGERANK</code> and the Hash-to-JSON encoding
        landed in <code>nodedb-ruby 0.1.0.alpha.5</code>.
      </div>
    </div>
    <div class="col-auto">
      <%= link_to social_nodes_path, class: "btn" do %>
        <i class="ti ti-arrow-left me-1"></i> Back
      <% end %>
    </div>
  </div>
</div>

<%= form_with url: recommend_social_nodes_path, method: :get, local: true, class: "mt-3" do |f| %>
  <div class="row g-2 align-items-end">
    <div class="col-md-4">
      <label class="form-label">Seed node</label>
      <%= f.select :seed, @nodes.map { |n| [n.id, n.id] }, { include_blank: "— pick a node —", selected: @seed },
                   class: "form-select" %>
    </div>
    <div class="col-auto">
      <%= f.submit "Recommend", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>

<% if @error %>
  <div class="alert alert-danger mt-3">
    <i class="ti ti-alert-circle me-1"></i> <%= @error %>
  </div>
<% end %>

<% if @seed %>
  <% ranked = @nodes.reject { |n| n.id == @seed }.sort_by { |n| -(@ranks[n.id] || 0.0) } %>
  <% max = (ranked.map { |n| @ranks[n.id] || 0.0 }.max || 0.0).nonzero? || 1.0 %>

  <div class="card mt-3">
    <div class="card-header">
      <h3 class="card-title">Top recommendations for <code><%= @seed %></code></h3>
      <div class="text-secondary small ms-auto">
        <code>personalization: { "<%= @seed %>" =&gt; 1.0 }</code>
      </div>
    </div>
    <div class="table-responsive">
      <table class="table table-vcenter card-table">
        <thead>
          <tr><th>Node</th><th>Name</th><th>Score</th><th>Bias</th></tr>
        </thead>
        <tbody>
          <% if ranked.empty? %>
            <tr><td colspan="4" class="text-secondary text-center">No other nodes to rank.</td></tr>
          <% else %>
            <% ranked.each do |n| %>
              <% score = @ranks[n.id] || 0.0 %>
              <tr>
                <td><code><%= n.id %></code></td>
                <td><%= n.name %></td>
                <td><span class="badge bg-blue-lt"><%= score.round(5) %></span></td>
                <td style="width: 35%;">
                  <div class="progress progress-sm">
                    <div class="progress-bar bg-azure" style="width: <%= ((score / max) * 100).round %>%"></div>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="empty mt-3">
    <p class="empty-title">Pick a seed node to personalize the ranking.</p>
    <p class="empty-subtitle text-secondary">
      The standard PageRank view (<%= link_to "Graph + PageRank", graph_social_nodes_path %>)
      uses the uniform teleport distribution. This view biases the teleport
      probability mass onto the seed so its neighborhood floats to the top.
    </p>
  </div>
<% end %>
