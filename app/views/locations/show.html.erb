<div class="mb-6 flex flex-wrap items-center justify-between gap-4 print:hidden">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight"><%= @location.name %></h1>
    <p class="text-sm text-muted-foreground"><code><%= @location.id %></code> · <%= @location.lat %>, <%= @location.lon %></p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to locations_path, class: "btn", data: { variant: "outline" } do %><i class="ti ti-arrow-left mr-1"></i> All<% end %>
    <%= button_to location_path(@location.id), method: :delete, data: { turbo_confirm: "Sure?", variant: "ghost" }, class: "btn text-destructive" do %>
      <i class="ti ti-trash mr-1"></i> Delete
    <% end %>
  </div>
</div>

<div class="card mt-4 overflow-hidden">
  <div id="map" style="height: 420px;"></div>
</div>

<%= javascript_include_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" %>
<%= stylesheet_link_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" %>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const lat = <%= @location.lat %>, lon = <%= @location.lon %>;
    const m = L.map("map").setView([lat, lon], 10);
    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", { attribution: "&copy; OSM" }).addTo(m);
    L.marker([lat, lon]).addTo(m).bindPopup(<%= @location.name.to_json.html_safe %>).openPopup();
  });
</script>
