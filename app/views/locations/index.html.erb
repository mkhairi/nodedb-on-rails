<div class="mb-6 flex flex-wrap items-center justify-between gap-4 print:hidden">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Locations &amp; Map</h1>
    <p class="text-muted-foreground"><%= pluralize(@locations.size, "pin") %> · document_strict + Ruby haversine</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to near_locations_path, class: "btn", data: { variant: "outline" } do %><i class="ti ti-current-location mr-1"></i> Find near<% end %>
    <%= link_to new_location_path, class: "btn" do %><i class="ti ti-plus mr-1"></i> Pin location<% end %>
  </div>
</div>

<div class="mt-4 grid gap-4 lg:grid-cols-3">
  <aside>
    <div class="card">
      <header>
        <h2>Pins</h2>
      </header>
      <% if @locations.any? %>
        <div class="divide-y border-t" id="pin-list">
          <% @locations.each do |loc| %>
            <div class="flex items-center px-4 py-2 hover:bg-muted/50"
                 data-loc-id="<%= loc.id %>" data-lat="<%= loc.lat %>" data-lon="<%= loc.lon %>" style="cursor: pointer;">
              <div class="mr-2"><span class="flex size-6 items-center justify-center rounded-full bg-muted text-muted-foreground"><i class="ti ti-map-pin"></i></span></div>
              <div class="flex-1">
                <div class="font-semibold"><%= loc.name.presence || "(unnamed)" %></div>
                <div class="text-sm text-muted-foreground"><code><%= loc.lat %>, <%= loc.lon %></code></div>
              </div>
              <div class="ml-2">
                <%= button_to location_path(loc.id), method: :delete, data: { turbo_confirm: "Sure?", variant: "ghost", size: "icon-sm" }, class: "btn text-destructive" do %>
                  <i class="ti ti-trash"></i>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <section>
          <div class="flex flex-col items-center gap-2 py-12 text-center text-muted-foreground">
            <i class="ti ti-map-pin-off text-3xl"></i>
            <div>No pins yet. <%= link_to "Add one", new_location_path %>.</div>
          </div>
        </section>
      <% end %>
    </div>
  </aside>

  <section class="lg:col-span-2">
    <div class="card overflow-hidden">
      <div id="map" style="height: 600px;"></div>
    </div>
  </section>
</div>

<%= javascript_include_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" %>
<%= stylesheet_link_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" %>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const m = L.map("map").setView([20, 0], 2);
    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", { attribution: "&copy; OSM" }).addTo(m);
    const points = <%= @locations.map { |l| { name: l.name, id: l.id, lat: l.lat, lon: l.lon } }.to_json.html_safe %>;
    const markersById = {};
    points.forEach(p => {
      const mk = L.marker([p.lat, p.lon]).addTo(m).bindPopup(`<a href="/locations/${p.id}">${p.name || "(unnamed)"}</a>`);
      markersById[p.id] = mk;
    });
    if (points.length) {
      m.fitBounds(L.featureGroup(Object.values(markersById)).getBounds(), { padding: [30, 30], maxZoom: 6 });
    }
    document.querySelectorAll("#pin-list [data-loc-id]").forEach(el => {
      el.addEventListener("click", evt => {
        if (evt.target.closest(".btn")) return;
        const id  = el.dataset.locId;
        const lat = +el.dataset.lat;
        const lon = +el.dataset.lon;
        m.flyTo([lat, lon], 8, { duration: 0.5 });
        markersById[id]?.openPopup();
      });
    });
  });
</script>
