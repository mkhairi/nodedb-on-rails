<div class="page-header"><h2 class="page-title">Pin a new location</h2></div>

<div class="card mt-3">
  <div class="card-body">
    <%= form_with url: locations_path, method: :post, local: true do |f| %>
      <div class="mb-3">
        <%= f.label "location[name]", "Name", class: "form-label" %>
        <%= f.text_field "location[name]", class: "form-control" %>
      </div>
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= f.label "location[lat]", "Latitude", class: "form-label" %>
          <%= f.number_field "location[lat]", step: "any", value: @location.lat, class: "form-control" %>
        </div>
        <div class="col-md-6 mb-3">
          <%= f.label "location[lon]", "Longitude", class: "form-label" %>
          <%= f.number_field "location[lon]", step: "any", value: @location.lon, class: "form-control" %>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Map picker <span class="form-label-description text-secondary">click or drag the marker</span></label>
        <div id="picker" style="height: 320px; border: 1px solid var(--tblr-border-color); border-radius: var(--tblr-border-radius);"></div>
      </div>

      <div class="btn-list">
        <%= f.submit "Save", class: "btn btn-primary" %>
        <%= link_to "Cancel", locations_path, class: "btn" %>
      </div>
    <% end %>
  </div>
</div>

<%= javascript_include_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" %>
<%= stylesheet_link_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" %>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const latInput = document.getElementsByName("location[lat]")[0];
    const lonInput = document.getElementsByName("location[lon]")[0];
    const m = L.map("picker").setView([+latInput.value, +lonInput.value], 4);
    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", { attribution: "&copy; OSM" }).addTo(m);
    let marker = L.marker([+latInput.value, +lonInput.value], { draggable: true }).addTo(m);
    marker.on("dragend", e => {
      const ll = e.target.getLatLng();
      latInput.value = ll.lat.toFixed(6);
      lonInput.value = ll.lng.toFixed(6);
    });
    m.on("click", e => {
      marker.setLatLng(e.latlng);
      latInput.value = e.latlng.lat.toFixed(6);
      lonInput.value = e.latlng.lng.toFixed(6);
    });
  });
</script>
