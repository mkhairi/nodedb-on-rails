<div class="mb-6">
  <h1 class="text-2xl font-semibold tracking-tight">Pin a new location</h1>
</div>

<div class="card mt-4">
  <section>
    <%= form_with url: locations_path, method: :post, local: true, html: { class: "space-y-6" } do |f| %>
      <div role="group" class="field">
        <%= f.label "location[name]", "Name" %>
        <%= f.text_field "location[name]", class: "input" %>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <div role="group" class="field">
          <%= f.label "location[lat]", "Latitude" %>
          <%= f.number_field "location[lat]", step: "any", value: @location.lat, class: "input" %>
        </div>
        <div role="group" class="field">
          <%= f.label "location[lon]", "Longitude" %>
          <%= f.number_field "location[lon]", step: "any", value: @location.lon, class: "input" %>
        </div>
      </div>

      <div role="group" class="field">
        <label>Map picker <span class="text-muted-foreground">click or drag the marker</span></label>
        <div id="picker" class="rounded-md border" style="height: 320px;"></div>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= f.submit "Save", class: "btn" %>
        <%= link_to "Cancel", locations_path, class: "btn", data: { variant: "outline" } %>
      </div>
    <% end %>
  </section>
</div>

<%= javascript_include_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" %>
<%= stylesheet_link_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" %>
<script>
  // Boot when Leaflet is ready: DOMContentLoaded never fires on Turbo Drive
  // visits, and the leaflet.js include loads async under a body swap.
  (function boot() {
    if (!window.L) return setTimeout(boot, 50);
    const latInput = document.getElementsByName("location[lat]")[0];
    const lonInput = document.getElementsByName("location[lon]")[0];
    const m = L.map("picker").setView([+latInput.value, +lonInput.value], 4);
    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", { attribution: "&copy; OSM" }).addTo(m);
    let marker = L.marker([+latInput.value, +lonInput.value], { draggable: true }).addTo(m);
    marker.on("dragend", e => {
      const ll = e.target.getLatLng();
      latInput.value = ll.lat.toFixed(6);
      lonInput.value = ll.lng.toFixed(6);
    });
    m.on("click", e => {
      marker.setLatLng(e.latlng);
      latInput.value = e.latlng.lat.toFixed(6);
      lonInput.value = e.latlng.lng.toFixed(6);
    });
  })();
</script>
