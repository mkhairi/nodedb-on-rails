<div class="mb-6">
  <h1 class="text-2xl font-semibold tracking-tight">Find near</h1>
</div>

<div class="card mt-4">
  <section>
    <%= form_with url: near_locations_path, method: :get, local: true, class: "grid gap-2 md:grid-cols-4" do |f| %>
      <div role="group" class="field">
        <%= f.label :lat, "Center lat" %>
        <%= f.number_field :lat, step: "any", value: @lat, class: "input" %>
      </div>
      <div role="group" class="field">
        <%= f.label :lon, "Center lon" %>
        <%= f.number_field :lon, step: "any", value: @lon, class: "input" %>
      </div>
      <div role="group" class="field">
        <%= f.label :meters, "Radius (m)" %>
        <%= f.number_field :meters, step: "any", value: @meters, class: "input" %>
      </div>
      <div class="flex items-end">
        <%= f.submit "Search", class: "btn w-full" %>
      </div>
    <% end %>
  </section>

  <% if @hits.any? %>
    <section class="border-t">
      <h2 class="font-semibold"><%= pluralize(@hits.size, "hit") %></h2>
    </section>
    <div class="table-container border-t">
      <table class="table">
        <thead><tr><th>Name</th><th>Lat</th><th>Lon</th><th>Distance</th></tr></thead>
        <tbody>
        <% @hits.each do |h| %>
          <tr>
            <td><%= link_to h.name.presence || "(unnamed)", location_path(h.id) %></td>
            <td><code><%= h.lat %></code></td>
            <td><code><%= h.lon %></code></td>
            <td>
              <span class="badge" data-variant="outline">
                <%= number_to_human((h.distance_m / 1000.0), units: { unit: "km" }, precision: 3) %>
              </span>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <section class="border-t py-8 text-center text-muted-foreground">No matches in that radius.</section>
  <% end %>
</div>
