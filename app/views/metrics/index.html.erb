<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">Timeseries</h2>
      <div class="text-secondary"><%= pluralize(@metrics.size, "recent point") %> · NodeDB timeseries engine (<code>metrics</code>)</div>
    </div>
  </div>
</div>

<% if @error %>
  <div class="alert alert-warning mt-3"><%= @error %></div>
<% end %>

<div class="card mt-3">
  <div class="card-header">
    <h3 class="card-title">
      Live system gauges
      <span class="badge bg-green-lt ms-2">REALTIME</span>
    </h3>
    <div class="text-secondary small ms-auto" id="live-status">
      polls <code>/metrics/live</code> every 3s — each tick INSERTs
      <code>sys.*</code> gauge rows and range-reads the last 10 minutes
    </div>
  </div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-lg-4"><div id="chart-cpu"></div></div>
      <div class="col-lg-4"><div id="chart-mem"></div></div>
      <div class="col-lg-4"><div id="chart-disk"></div></div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/apexcharts@5.16.0/dist/apexcharts.min.js"
        integrity="sha384-ev+0gnMiCR/xVXDO/DIRntnh/SqpByfMpm3uB8SFR/IkPnsSdZHnyi/NDdUZUXOv"
        crossorigin="anonymous"></script>
<script>
  (function () {
    const mk = (el, name, color, suffix) => new ApexCharts(
      document.querySelector(el), {
        chart: { type: "area", height: 220, animations: { enabled: true, dynamicAnimation: { speed: 800 } },
                 toolbar: { show: false }, zoom: { enabled: false } },
        series: [{ name: name, data: [] }],
        stroke: { curve: "smooth", width: 2 },
        fill: { type: "gradient", gradient: { opacityFrom: 0.35, opacityTo: 0.05 } },
        colors: [color],
        dataLabels: { enabled: false },
        title: { text: name, style: { fontSize: "13px" } },
        xaxis: { type: "datetime", labels: { datetimeUTC: false } },
        yaxis: { labels: { formatter: v => v == null ? "" : v.toFixed(1) + suffix }, min: 0 },
        tooltip: { x: { format: "HH:mm:ss" } }
      });

    const panels = {
      "sys.cpu_load": { label: "CPU load (1m)",    chart: mk("#chart-cpu",  "CPU load (1m)",    "#206bc4", "") },
      "sys.mem_mb":   { label: "Process RSS (MB)", chart: mk("#chart-mem",  "Process RSS (MB)", "#2fb344", " MB") },
      "sys.disk_pct": { label: "Disk / used (%)",  chart: mk("#chart-disk", "Disk / used (%)",  "#f76707", "%") }
    };
    Object.values(panels).forEach(p => p.chart.render());

    const status = document.getElementById("live-status");
    async function tick() {
      try {
        const res  = await fetch("<%= live_metrics_path %>", { headers: { Accept: "application/json" } });
        const body = await res.json();
        if (!res.ok) throw new Error(body.error || res.status);
        body.series.forEach(s => {
          const p = panels[s.name];
          if (p) p.chart.updateSeries([{ name: p.label, data: s.data }]);
        });
        status.textContent = "live · " + new Date().toLocaleTimeString() +
          " · " + body.series.reduce((n, s) => n + s.data.length, 0) + " points in window";
      } catch (e) {
        status.textContent = "feed error: " + e.message + " (retrying)";
      }
    }
    tick();
    setInterval(tick, 3000);
  })();
</script>

<div class="row mt-3 g-3">
  <div class="col-lg-5">
    <div class="card h-100">
      <div class="card-header"><h3 class="card-title">Record a point</h3></div>
      <div class="card-body">
        <%= form_with url: metrics_path, method: :post, local: true, class: "row g-2" do |f| %>
          <div class="col-5">
            <%= f.text_field :host, value: "web-01", class: "form-control", placeholder: "host" %>
          </div>
          <div class="col-4">
            <%= f.text_field :value, value: "0.5", class: "form-control", placeholder: "value" %>
          </div>
          <div class="col-3">
            <%= f.submit "Add", class: "btn btn-primary w-100" %>
          </div>
        <% end %>
        <p class="text-secondary small mt-2 mb-0">
          Timestamp is set to <code>now()</code> server-side.
        </p>
      </div>
    </div>

    <div class="card mt-3">
      <div class="card-header">
        <h3 class="card-title">Avg value / 1-minute bucket</h3>
      </div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <thead><tr><th>Bucket</th><th>Host</th><th class="text-end">Avg</th></tr></thead>
          <tbody>
            <% if @buckets.empty? %>
              <tr><td colspan="3" class="text-secondary">
                No aggregate rows yet — insert some metrics above.
              </td></tr>
            <% else %>
              <% @buckets.each do |b| %>
                <tr>
                  <td class="small"><code><%= b["bucket"] %></code></td>
                  <td><%= b["host"] %></td>
                  <td class="text-end"><code><%= b["avg_value"] %></code></td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-7">
    <div class="card h-100">
      <div class="card-header"><h3 class="card-title">Recent points</h3></div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <thead><tr><th>Timestamp</th><th>Host</th><th class="text-end">Value</th></tr></thead>
          <tbody>
            <% if @metrics.empty? %>
              <tr><td colspan="3" class="text-secondary">No metrics yet — add one or run <code>bin/rails runner db/seeds.rb</code>.</td></tr>
            <% else %>
              <% @metrics.each do |m| %>
                <tr>
                  <td class="small"><code><%= m.ts %></code></td>
                  <td><span class="badge bg-blue-lt"><%= m.host %></span></td>
                  <td class="text-end"><code><%= m.value %></code></td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
