<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Timeseries</h1>
    <div class="text-muted-foreground"><%= pluralize(@metrics.size, "recent point") %> · NodeDB timeseries engine (<code>metrics</code>)</div>
  </div>
</div>

<% if @error %>
  <div class="alert mt-4" role="alert">
    <i class="ti ti-alert-circle"></i>
    <h2><%= @error %></h2>
  </div>
<% end %>

<div class="card mt-4">
  <header>
    <h2>
      Live system gauges
      <span class="badge text-green-600 ml-2" data-variant="outline">REALTIME</span>
    </h2>
    <div class="card-action text-muted-foreground text-sm" id="live-status">
      polls <code>/metrics/live</code> every 3s — each tick INSERTs
      <code>sys.*</code> gauge rows and range-reads the last 10 minutes
    </div>
  </header>
  <section>
    <div class="grid gap-4 lg:grid-cols-3">
      <div><div id="chart-cpu"></div></div>
      <div><div id="chart-mem"></div></div>
      <div><div id="chart-disk"></div></div>
    </div>
  </section>
</div>

<script id="apexcharts-cdn"
        src="https://cdn.jsdelivr.net/npm/apexcharts@5.16.0/dist/apexcharts.min.js"
        integrity="sha384-ev+0gnMiCR/xVXDO/DIRntnh/SqpByfMpm3uB8SFR/IkPnsSdZHnyi/NDdUZUXOv"
        crossorigin="anonymous"></script>
<script>
  (function () {
    // Under Turbo Drive body swaps the external script above loads async,
    // so wait for it instead of assuming ApexCharts is already defined.
    function start() {
    const mk = (el, name, color, suffix) => new ApexCharts(
      document.querySelector(el), {
        chart: { type: "area", height: 220, animations: { enabled: true, dynamicAnimation: { speed: 800 } },
                 toolbar: { show: false }, zoom: { enabled: false } },
        series: [{ name: name, data: [] }],
        stroke: { curve: "smooth", width: 2 },
        fill: { type: "gradient", gradient: { opacityFrom: 0.35, opacityTo: 0.05 } },
        colors: [color],
        dataLabels: { enabled: false },
        title: { text: name, style: { fontSize: "13px" } },
        xaxis: { type: "datetime", labels: { datetimeUTC: false } },
        yaxis: { labels: { formatter: v => v == null ? "" : v.toFixed(1) + suffix }, min: 0 },
        tooltip: { x: { format: "HH:mm:ss" } }
      });

    const panels = {
      "sys.cpu_load": { label: "CPU load (1m)",    chart: mk("#chart-cpu",  "CPU load (1m)",    "#206bc4", "") },
      "sys.mem_mb":   { label: "Process RSS (MB)", chart: mk("#chart-mem",  "Process RSS (MB)", "#2fb344", " MB") },
      "sys.disk_pct": { label: "Disk / used (%)",  chart: mk("#chart-disk", "Disk / used (%)",  "#f76707", "%") }
    };
    Object.values(panels).forEach(p => p.chart.render());

    const status = document.getElementById("live-status");
    async function tick() {
      try {
        const res  = await fetch("<%= live_metrics_path %>", { headers: { Accept: "application/json" } });
        const body = await res.json();
        if (!res.ok) throw new Error(body.error || res.status);
        body.series.forEach(s => {
          const p = panels[s.name];
          if (p) p.chart.updateSeries([{ name: p.label, data: s.data }]);
        });
        status.textContent = "live · " + new Date().toLocaleTimeString() +
          " · " + body.series.reduce((n, s) => n + s.data.length, 0) + " points in window";
      } catch (e) {
        status.textContent = "feed error: " + e.message + " (retrying)";
      }
    }
    tick();
    const timer = setInterval(tick, 3000);
    // Stop polling when Turbo swaps the page out, or the loop keeps
    // fetching /metrics/live forever after navigating away.
    document.addEventListener("turbo:before-render", () => clearInterval(timer), { once: true });
    }

    if (window.ApexCharts) start();
    else document.getElementById("apexcharts-cdn").addEventListener("load", start, { once: true });
  })();
</script>

<div class="grid gap-4 mt-2 lg:grid-cols-2">
  <div class="lg:col-span-2">
    <div class="card">
      <header><h2>Record a point</h2></header>
      <section>
        <%= form_with url: metrics_path, method: :post, local: true, class: "grid grid-cols-12 gap-2" do |f| %>
          <div class="col-span-5">
            <%= f.text_field :host, value: "web-01", class: "input", placeholder: "host" %>
          </div>
          <div class="col-span-4">
            <%= f.text_field :value, value: "0.5", class: "input", placeholder: "value" %>
          </div>
          <div class="col-span-3">
            <%= f.submit "Add", class: "btn w-full" %>
          </div>
        <% end %>
        <p class="text-muted-foreground text-sm mt-2 mb-0">
          Timestamp is set to <code>now()</code> server-side.
        </p>
      </section>
    </div>
  </div>
  <div>
    <div class="card h-full">
      <header>
        <h2>Avg value / 1-minute bucket</h2>
      </header>
      <section>
        <div class="table-container">
          <table class="table">
            <thead><tr><th>Bucket</th><th>Host</th><th class="text-end">Avg</th></tr></thead>
            <tbody>
              <% if @buckets.empty? %>
                <tr><td colspan="3" class="text-muted-foreground">
                  No aggregate rows yet — insert some metrics above.
                </td></tr>
              <% else %>
                <% @buckets.each do |b| %>
                  <tr>
                    <td class="text-sm"><code><%= b["bucket"] %></code></td>
                    <td><%= b["host"] %></td>
                    <td class="text-end"><code><%= b["avg_value"] %></code></td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </div>
  <div>
    <div class="card h-full">
      <header><h2>Recent points</h2></header>
      <section>
        <div class="table-container">
          <table class="table">
            <thead><tr><th>Timestamp</th><th>Host</th><th class="text-end">Value</th></tr></thead>
            <tbody>
              <% if @metrics.empty? %>
                <tr><td colspan="3" class="text-muted-foreground">No metrics yet — add one or run <code>bin/rails runner db/seeds.rb</code>.</td></tr>
              <% else %>
                <% @metrics.each do |m| %>
                  <tr>
                    <td class="text-sm"><code><%= m.ts %></code></td>
                    <td><span class="badge text-blue-600" data-variant="outline"><%= m.host %></span></td>
                    <td class="text-end"><code><%= m.value %></code></td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </div>
</div>
