<div class="mb-6 flex flex-wrap items-center justify-between gap-4 print:hidden">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Articles</h1>
    <div class="text-muted-foreground"><%= pluralize(@articles.size, "article") %></div>
  </div>
  <div class="flex gap-2">
    <%= link_to new_article_path, class: "btn" do %>
      <i class="ti ti-plus mr-1"></i> New article
    <% end %>
  </div>
</div>

<div class="card mt-4">
  <section class="border-b py-3">
    <%= form_with url: search_articles_path, method: :get, local: true, class: "flex gap-2" do |f| %>
      <div class="flex-1">
        <%= f.text_field :q, value: @query, placeholder: "Search title…", class: "input" %>
      </div>
      <div><%= f.submit "Search", class: "btn", data: { variant: "outline" } %></div>
    <% end %>
  </section>
  <% if @articles.any? %>
    <div class="table-container">
      <table class="table">
        <thead><tr><th>ID</th><th>Title</th><th class="w-px">Actions</th></tr></thead>
        <tbody>
          <% @articles.each do |article| %>
            <tr>
              <td class="text-muted-foreground"><code><%= article.id&.first(8) %></code></td>
              <td><%= link_to article.title, article %></td>
              <td>
                <div class="flex flex-nowrap gap-2">
                  <%= link_to "Edit", edit_article_path(article), class: "btn", data: { variant: "outline", size: "sm" } %>
                  <%= button_to "Delete", article_path(article), method: :delete, data: { turbo_confirm: "Sure?", variant: "ghost", size: "sm" }, class: "btn text-destructive" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <section>
      <div class="flex flex-col items-center gap-2 py-12 text-muted-foreground">
        <i class="ti ti-files-off text-4xl"></i>
        <div>No articles yet. <%= link_to "Write one", new_article_path %>.</div>
      </div>
    </section>
  <% end %>
</div>
